# =============================================================================
# Application Configuration
# =============================================================================

# Runtime environment: development | production | test
NODE_ENV=production

# Port the application listens on (inside the container)
PORT=3000

# Public-facing URL of the deployed application
APP_URL=https://yourdomain.com

# =============================================================================
# Database
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://appuser:changeme@db:5432/appdb

# Redis connection string (if used for caching/sessions)
# REDIS_URL=redis://redis:6379

# =============================================================================
# Authentication & Secrets
# =============================================================================

# Secret used for signing JWTs or session cookies (generate a strong random string)
# Generate with: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-random-string

# NextAuth.js URL (if using NextAuth)
# NEXTAUTH_URL=https://yourdomain.com
# NEXTAUTH_SECRET=change-me-to-a-random-string

# =============================================================================
# Third-Party API Keys
# =============================================================================

# OpenAI (if the app uses AI features)
# OPENAI_API_KEY=sk-...

# Stripe (if the app has payments)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# AWS S3 (if the app uploads files)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# =============================================================================
# Email / SMTP
# =============================================================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# =============================================================================
# CORS & Security
# =============================================================================

# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# Logging
# =============================================================================

# Log level: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# Docker / Infrastructure
# =============================================================================

# Domain name for Nginx and SSL
DOMAIN=yourdomain.com

# Email for Let's Encrypt SSL certificate notifications
SSL_EMAIL=your-email@example.com
